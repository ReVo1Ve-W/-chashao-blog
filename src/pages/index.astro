---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				padding-top: 0;
			}
			.hero {
				text-align: center;
				padding: 4em 1em 3em;
			}
			.hero h1 {
				font-size: 2.8em;
			}
			.hero p {
				max-width: 42em;
				margin: 0 auto 0.5em;
				color: rgb(var(--gray));
				font-size: 1.1em;
			}
			.hero .cta {
				display: inline-block;
				margin-top: 1em;
				padding: 0.6em 1.5em;
				border-radius: 999px;
				background: var(--accent);
				color: white;
				text-decoration: none;
				font-weight: 700;
				transition: background 0.15s ease;
			}
			.hero .cta:hover {
				background: var(--accent-dark);
				color: white;
			}
			section {
				padding: 1em 1em 3em;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 1.5rem;
			}
			.section-head h2 {
				margin: 0;
				font-size: 1.6em;
			}
			.section-head a {
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.95em;
			}
			.section-head a:hover {
				color: var(--accent);
			}
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5rem;
			}
			.post-card {
				display: block;
				background: rgb(var(--bg-elevated));
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
				overflow: hidden;
				text-decoration: none;
				transition:
					transform 0.15s ease,
					box-shadow 0.15s ease;
			}
			.post-card:hover {
				transform: translateY(-3px);
			}
			.post-card img {
				display: block;
				width: 100%;
				aspect-ratio: 2 / 1;
				object-fit: cover;
				border-radius: 0;
			}
			.post-card .card-body {
				padding: 1.1rem 1.25rem 1.3rem;
			}
			.post-card .title {
				margin: 0 0 0.4rem 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.15em;
			}
			.post-card:hover .title {
				color: var(--accent);
			}
			.post-card .date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.about-teaser {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				background: rgb(var(--bg-elevated));
				border-radius: var(--radius);
				box-shadow: var(--box-shadow);
				padding: 2em;
			}
			.about-teaser .avatar {
				flex-shrink: 0;
				width: 88px;
				height: 88px;
				border-radius: 50%;
				background: var(--accent);
				color: white;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2.2em;
			}
			.about-teaser p {
				margin: 0 0 0.6em 0;
				color: rgb(var(--gray-dark));
			}
			.about-teaser a {
				font-weight: 700;
			}
			@media (max-width: 720px) {
				.hero {
					padding: 2.5em 0.5em 2em;
				}
				.hero h1 {
					font-size: 2em;
				}
				.posts-grid {
					grid-template-columns: 1fr;
				}
				.about-teaser {
					flex-direction: column;
					text-align: center;
					padding: 1.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>你好，我是叉烧 👋</h1>
				<p>这里是叉烧的个人博客，记录代码相关的技术笔记，也写点生活里的随笔。</p>
				<a class="cta" href="/blog">看看都写了什么 →</a>
			</div>

			{
				recentPosts.length > 0 && (
					<section>
						<div class="section-head">
							<h2>最新文章</h2>
							<a href="/blog">查看全部 →</a>
						</div>
						<div class="posts-grid">
							{recentPosts.map((post) => (
								<a class="post-card" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={480} height={240} src={post.data.heroImage} alt="" />
									)}
									<div class="card-body">
										<h3 class="title">{post.data.title}</h3>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							))}
						</div>
					</section>
				)
			}

			<section>
				<div class="about-teaser">
					<div class="avatar">🍖</div>
					<div>
						<p>不写文章的时候，叉烧也会到处逛逛、随手记点东西。想多了解一下的话——</p>
						<a href="/about">关于我 →</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
